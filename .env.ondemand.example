HOST=0.0.0.0
PORT=39173
PROXY_API_KEY=change-me-long-random-string
DEFAULT_MODEL=mimo-auto

MIMO_BIN=/root/.local/bin/mimo
MIMO_PORT=39450
MIMO_WORKDIR=/opt/mimo-free-proxy/work
MIMO_CONFIG_HOME=/opt/mimo-free-proxy/config
MIMO_PROXY_URL=http://127.0.0.1:7890
MIMO_IDLE_TIMEOUT=15m
MIMO_START_TIMEOUT=45s

# Optional detailed health checks. Set the expected IP to detect route changes.
HEALTH_EXPECTED_EXIT_IP=
HEALTH_CHECK_TIMEOUT=8s
HEALTH_CACHE_TTL=1m
HEALTH_IP_URL=https://api.ipify.org?format=json
HEALTH_UPSTREAM_URL=https://api.xiaomimimo.com/
