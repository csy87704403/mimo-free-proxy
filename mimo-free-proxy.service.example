[Unit]
Description=MiMo Free OpenAI-Compatible Proxy
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/mimo-free-proxy
EnvironmentFile=/etc/mimo-free-proxy.env
ExecStart=/usr/bin/env node /opt/mimo-free-proxy/server.js
Restart=always
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
